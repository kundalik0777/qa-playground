# =============================================================================
# SECTION 1 — QA Playground: Next.js App (qaplayground.com)
# Local dev  : copy to root .env
# Production : paste into Vercel → Project Settings → Environment Variables
# =============================================================================

# Environment
NODE_ENV="development"
PORT=3000

# Database (Supabase PostgreSQL)
# Use the pooler URL for the app, direct URL for Prisma migrations
DATABASE_URL="postgresql://postgres.YOUR_PROJECT_REF:YOUR_PASSWORD@aws-0-REGION.pooler.supabase.com:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres.YOUR_PROJECT_REF:YOUR_PASSWORD@aws-0-REGION.pooler.supabase.com:5432/postgres"

# Public site URL (used for OG tags, sitemap, etc.)
NEXT_PUBLIC_APP_URL="https://qaplayground.com"

# Auth (Better-Auth) 
BETTER_AUTH_SECRET="your-32-char-random-secret"
BETTER_AUTH_URL="https://qaplayground.com"          # use http://localhost:3000 for local dev
BETTER_AUTH_RATE_LIMIT="false"                       # set "false" to disable rate limit in dev/testing

# Google OAuth (Better-Auth social provider)
# Get these from Google Cloud Console → Credentials → OAuth 2.0 Client ID
# Redirect URIs to add: http://localhost:3000/api/auth/callback/google (dev)
#                       https://www.qaplayground.com/api/auth/callback/google (prod)
GOOGLE_CLIENT_ID="your-google-client-id.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="your-google-client-secret"

# Email — Resend (domain qaplayground.com must be verified in Resend dashboard)
RESEND_API_KEY="re_your_resend_api_key"
RESEND_FROM_EMAIL="noreply@qaplayground.com"

# ReqRes (mock REST API for practice elements)
REGRESS_FREE_API_KEY="reqres_your_api_key"

# Upstash Redis (rate limiting / caching)
UPSTASH_REDIS_REST_URL="https://your-instance.upstash.io"
UPSTASH_REDIS_REST_TOKEN="your_upstash_token"

# Telegram Bot
TELEGRAM_BOT_TOKEN="your_telegram_bot_token"
TELEGRAM_WEBHOOK_SECRET="your_telegram_webhook_secret"

# OpenAI (used for AI features inside the app)
OPENAI_API_KEY="sk-proj-your_openai_api_key"
OPENAI_MODEL="gpt-4o"

# Interview Practice — Next.js side
# URL where the WS server is running (localhost for dev, hosted URL for prod)
INTERVIEW_WS_URL="ws://localhost:3001/interview-practice/ws"
# Shared secret — must match INTERVIEW_WS_INTERNAL_SECRET in the WS server
INTERVIEW_WS_INTERNAL_SECRET="your_shared_secret_min_32_chars"


# =============================================================================
# SECTION 2 — Interview WebSocket Server (server/interview-ws)
# Local dev  : already auto-loaded from root .env — no separate file needed
# Production : set these as env vars in your WS server host (Railway / Fly / VPS)
# =============================================================================

# WS server port
INTERVIEW_WS_PORT="3001"

# Deepgram API key — used server-side only to connect to Deepgram Agent API
# Get it from: https://console.deepgram.com
DEEPGRAM_API_KEY="your_deepgram_api_key"

# Base URL of the Next.js app (WS server calls back here to validate sessions)
INTERVIEW_API_BASE_URL="http://localhost:3000"

# Comma-separated list of origins allowed to connect to the WS server
ALLOWED_ORIGINS="http://localhost:3000,http://127.0.0.1:3000"

# Path to the interview agent guidelines markdown file (relative to repo root)
INTERVIEW_AGENT_GUIDELINES_PATH="packages/interview-core/INTERVIEW_AGENT_GUIDELINES.md"

# Shared secret — must match INTERVIEW_WS_INTERNAL_SECRET in the Next.js app
INTERVIEW_WS_INTERNAL_SECRET="your_shared_secret_min_32_chars"
