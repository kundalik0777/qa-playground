FROM node:22-alpine

WORKDIR /app

RUN corepack enable

COPY package.json pnpm-lock.yaml pnpm-workspace.yaml turbo.json ./
COPY packages/interview-core ./packages/interview-core
COPY server/interview-ws ./server/interview-ws

RUN pnpm install --frozen-lockfile

CMD ["pnpm", "--filter", "@qa-playground/interview-ws", "start"]
